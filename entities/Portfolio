{
  "name": "Portfolio",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Portfolio simulation name"
    },
    "description": {
      "type": "string"
    },
    "strategy": {
      "type": "string",
      "enum": [
        "conservative",
        "moderate",
        "aggressive",
        "custom"
      ],
      "default": "moderate"
    },
    "initial_capital": {
      "type": "number",
      "description": "Simulated starting capital (paper only)"
    },
    "currency": {
      "type": "string",
      "default": "USD"
    },
    "holdings": {
      "type": "array",
      "description": "Paper portfolio positions",
      "items": {
        "type": "object",
        "properties": {
          "ticker": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "allocation_pct": {
            "type": "number"
          },
          "allocation_amount": {
            "type": "number"
          },
          "shares": {
            "type": "number"
          },
          "avg_cost": {
            "type": "number"
          },
          "current_price": {
            "type": "number"
          },
          "current_value": {
            "type": "number"
          },
          "position_type": {
            "type": "string",
            "enum": [
              "long",
              "short"
            ]
          },
          "signal_score": {
            "type": "number"
          },
          "signal_strength": {
            "type": "number"
          },
          "article_count": {
            "type": "number"
          },
          "sector": {
            "type": "string"
          }
        }
      }
    },
    "simulation_confirmed": {
      "type": "boolean",
      "default": false,
      "description": "User must explicitly confirm before simulation runs"
    },
    "simulation_status": {
      "type": "string",
      "enum": [
        "draft",
        "confirmed",
        "running",
        "complete",
        "error"
      ],
      "default": "draft"
    },
    "source_mode": {
      "type": "string",
      "enum": [
        "manual",
        "signal_driven"
      ],
      "default": "signal_driven"
    },
    "signal_threshold": {
      "type": "number"
    },
    "source_news_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "simulation_results": {
      "type": "object",
      "description": "Output of paper simulation \u2014 educational only",
      "properties": {
        "total_return_pct": {
          "type": "number"
        },
        "annualized_return_pct": {
          "type": "number"
        },
        "max_drawdown_pct": {
          "type": "number"
        },
        "sharpe_ratio": {
          "type": "number"
        },
        "volatility_pct": {
          "type": "number"
        },
        "benchmark_return_pct": {
          "type": "number"
        },
        "current_value": {
          "type": "number"
        },
        "live_value": {
          "type": "number"
        },
        "live_value_as_of": {
          "type": "string"
        },
        "benchmark_symbol": {
          "type": "string"
        },
        "data_source": {
          "type": "string"
        },
        "period_days": {
          "type": "number"
        },
        "data_points": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "disclaimer_version": {
      "type": "string",
      "description": "Version of disclaimer user acknowledged"
    }
  },
  "required": [
    "name",
    "initial_capital"
  ]
}