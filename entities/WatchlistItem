{
  "name": "WatchlistItem",
  "type": "object",
  "properties": {
    "ticker": {
      "type": "string",
      "description": "Stock ticker symbol"
    },
    "company_name": {
      "type": "string"
    },
    "sector": {
      "type": "string"
    },
    "notes": {
      "type": "string",
      "description": "User research notes"
    },
    "alert_keywords": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Keywords to flag in news for this ticker"
    },
    "sentiment_threshold": {
      "type": "string",
      "enum": [
        "any",
        "bullish_only",
        "bearish_only"
      ],
      "default": "any"
    }
  },
  "required": [
    "ticker"
  ]
}