{
  "name": "NewsItem",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Article headline"
    },
    "source": {
      "type": "string",
      "description": "Publisher/source name"
    },
    "source_url": {
      "type": "string",
      "description": "Original article URL"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "Publication timestamp"
    },
    "summary": {
      "type": "string",
      "description": "Brief article summary"
    },
    "full_content": {
      "type": "string",
      "description": "Full article text or extended excerpt"
    },
    "entities": {
      "type": "array",
      "description": "Extracted companies, tickers, and sectors",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "company",
              "ticker",
              "sector",
              "macro"
            ]
          },
          "ticker": {
            "type": "string"
          }
        }
      }
    },
    "sentiment": {
      "type": "string",
      "enum": [
        "bullish",
        "bearish",
        "neutral",
        "mixed"
      ],
      "description": "Analytical sentiment signal \u2014 not a financial recommendation"
    },
    "sentiment_score": {
      "type": "number",
      "description": "Sentiment score -1.0 to 1.0"
    },
    "sector_tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Relevant market sectors"
    },
    "macro_signals": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Macroeconomic signals detected"
    },
    "signal_facts": {
      "type": [
        "object",
        "null"
      ],
      "description": "Structured ticker/topic/event extraction used for long-term signal memory",
      "properties": {
        "extraction_version": {
          "type": "number"
        },
        "extracted_at": {
          "type": "string",
          "format": "date-time"
        },
        "sentiment": {
          "type": "string"
        },
        "sentiment_score": {
          "type": "number"
        },
        "source_credibility_score": {
          "type": "number"
        },
        "uncertainty_score": {
          "type": "number"
        },
        "primary_ticker": {
          "type": [
            "string",
            "null"
          ]
        },
        "tickers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ticker": { "type": "string" },
              "name": { "type": "string" },
              "entity_type": { "type": "string" }
            }
          }
        },
        "topics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "label": { "type": "string" }
            }
          }
        },
        "events": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "analysis_status": {
      "type": "string",
      "enum": [
        "pending",
        "analyzing",
        "complete",
        "error"
      ],
      "default": "pending"
    },
    "ingestion_source": {
      "type": "string",
      "enum": [
        "rss_manual",
        "user_submitted",
        "api_fetch"
      ],
      "default": "user_submitted"
    }
  },
  "required": [
    "title",
    "source"
  ]
}