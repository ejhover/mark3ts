{
  "name": "AuditLog",
  "type": "object",
  "properties": {
    "event_type": {
      "type": "string",
      "enum": [
        "news_ingested",
        "analysis_run",
        "hypothesis_generated",
        "simulation_confirmed",
        "simulation_run",
        "integration_activated",
        "disclaimer_acknowledged",
        "user_action"
      ]
    },
    "entity_type": {
      "type": "string",
      "description": "Type of entity involved (NewsItem, Hypothesis, Portfolio)"
    },
    "entity_id": {
      "type": "string",
      "description": "ID of the related entity"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the event"
    },
    "ai_model_used": {
      "type": "string",
      "description": "AI model identifier if AI was involved"
    },
    "input_summary": {
      "type": "string",
      "description": "Summary of input data used"
    },
    "output_summary": {
      "type": "string",
      "description": "Summary of output produced"
    },
    "sources_cited": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Source URLs cited"
    },
    "user_confirmed": {
      "type": "boolean",
      "default": false
    },
    "metadata": {
      "type": "object",
      "description": "Additional structured metadata"
    }
  },
  "required": [
    "event_type",
    "description"
  ]
}